<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Todo List - Level 3</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5" style="max-width: 800px;">
    
    <div class="alert alert-info d-flex justify-content-between align-items-center">
    <strong>Bạn đang đóng vai: <%= currentUser.username %></strong> 
    <form action="/" method="GET" class="d-flex">
        <select name="userId" class="form-select form-select-sm me-2">
            <% users.forEach(u => { %>
                <option value="<%= u._id %>" <%= u._id.toString() === currentUser._id.toString() ? 'selected' : '' %>>
                    <%= u.username %>
                </option>
            <% }) %>
        </select>
        <button type="submit" class="btn btn-sm btn-secondary">Đổi User</button>
    </form>
</div>

    <h2 class="text-center mb-4">Quản Lý Công Việc Nhóm</h2>

    <% 
        let total = tasks.length;
        let completed = tasks.filter(t => t.isDone).length;
        let percent = total === 0 ? 0 : Math.round((completed / total) * 100);
    %>
    <div class="progress mb-4">
        <div class="progress-bar bg-success" style="width: <%= percent %>%"><%= percent %>% Tiến độ dự án</div>
    </div>

    <form action="/tasks/add" method="POST" class="d-flex mb-4">
        <input type="hidden" name="creatorId" value="<%= currentUser._id %>">
        <input type="text" name="title" class="form-control me-2" placeholder="Nhập công việc..." required>
        <button type="submit" class="btn btn-primary">Thêm</button>
    </form>

    <ul class="list-group">
        <% tasks.forEach(task => { %>
            <li class="list-group-item <%= task.isDone ? 'list-group-item-success' : '' %>">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 style="<%= task.isDone ? 'text-decoration: line-through;' : '' %>"><%= task.title %></h5>
                    
                    <form action="/tasks/delete/<%= task._id %>" method="POST">
                        <input type="hidden" name="currentUserId" value="<%= currentUser._id %>">
                        <button class="btn btn-danger btn-sm">Xóa Task</button>
                    </form>
                </div>

                <% if (currentUser.role === 'admin') { %>
                    <form action="/tasks/assign/<%= task._id %>" method="POST" class="d-flex mb-2">
                        <input type="hidden" name="currentAdminId" value="<%= currentUser._id %>">
                        <select name="targetUserId" class="form-select form-select-sm me-2" style="width: auto;">
                            <% users.filter(u => u.role === 'normal').forEach(u => { %>
                                <option value="<%= u._id %>">Giao cho: <%= u.username %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-warning btn-sm">Phân việc</button>
                    </form>
                <% } %>

                <div>
                    <small>Người đang làm:</small>
                    <% task.assignees.forEach(assignee => { %>
                        <span class="badge <%= assignee.isUserDone ? 'bg-success' : 'bg-secondary' %> me-1">
                            <%= assignee.user.username %> <%= assignee.isUserDone ? '(Đã xong)' : '(Đang làm)' %>
                        </span>
                        
                        <% if (assignee.user._id.toString() === currentUser._id.toString() && !assignee.isUserDone) { %>
                            <form action="/tasks/done/<%= task._id %>" method="POST" style="display:inline;">
                                <input type="hidden" name="currentUserId" value="<%= currentUser._id %>">
                                <button type="submit" class="btn btn-success btn-sm ms-2">Bấm hoàn thành việc của tôi</button>
                            </form>
                        <% } %>
                    <% }) %>
                </div>
            </li>
        <% }) %>
    </ul>
</body>
</html>